import MainBackground from "@/components/MainBackground.vue";
import Kline from 'kline';

export default {
    name: 'myTransaction',
    components: {
        MainBackground,
    },
    methods: {
        setupKline() {
            var kline = new Kline({
                element: "#kline_container",
                symbol: "BTC",
                symbolName: "比特币",
                type: "poll",
                url: "http://127.0.0.1:8080/mock.json"
            });
            kline.draw();
            kline.resize(900, 650);
            kline.setShowTrade(false);  // true/false
        }
    },
    mounted() {
        this.setupKline();
    }
};
